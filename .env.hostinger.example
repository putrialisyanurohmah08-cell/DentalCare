APP_NAME="DentalCare Lite"
APP_ENV=production
APP_KEY=base64:ISI_DENGAN_APP_KEY_DARI_ENV_LOKAL_ATAU_GENERATE_BARU
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://ISI_TEMPORARY_DOMAIN_HOSTINGER
APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID
APP_COMPANY_CODE=DCL

CLINIC_NAME="DentalCare Lite"
CLINIC_TAGLINE="Klinik gigi modern untuk keluarga dengan reservasi online yang mudah."
CLINIC_ADDRESS="ISI_ALAMAT_KLINIK"
CLINIC_PHONE="ISI_NOMOR_TELEPON"
CLINIC_EMAIL=ISI_EMAIL_KLINIK

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=ISI_NAMA_DATABASE_HOSTINGER
DB_USERNAME=ISI_USERNAME_DATABASE_HOSTINGER
DB_PASSWORD=ISI_PASSWORD_DATABASE_HOSTINGER

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=database
CACHE_PREFIX=

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=ISI_EMAIL_SMTP
MAIL_PASSWORD=ISI_PASSWORD_SMTP
MAIL_FROM_ADDRESS=ISI_EMAIL_SMTP
MAIL_FROM_NAME="${APP_NAME}"

LOGIN_OTP_DIGITS=6
LOGIN_OTP_EXPIRES_MINUTES=10
LOGIN_OTP_MAX_ATTEMPTS=5
LOGIN_OTP_RESEND_COOLDOWN_SECONDS=60

GOOGLE_CLIENT_ID=ISI_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=ISI_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

MIDTRANS_MERCHANT_ID=ISI_MIDTRANS_MERCHANT_ID
MIDTRANS_SERVER_KEY=ISI_MIDTRANS_SERVER_KEY
MIDTRANS_CLIENT_KEY=ISI_MIDTRANS_CLIENT_KEY
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_CALLBACK_URL="${APP_URL}/payments/midtrans/callback"

APPOINTMENT_SLOT_MINUTES=30
VITE_APP_NAME="${APP_NAME}"
