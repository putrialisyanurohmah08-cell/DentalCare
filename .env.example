APP_NAME="DentalCare Lite"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost:8080
APP_BIND=127.0.0.1
APP_PORT=8080
VITE_PORT=5173

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_COMPANY_CODE=DCL
CLINIC_NAME="DentalCare Lite"
CLINIC_TAGLINE="Klinik gigi modern untuk keluarga dengan reservasi online yang mudah."
CLINIC_ADDRESS="Jl. Senyum Sehat No. 12, Jakarta"
CLINIC_PHONE="+62 812-3456-7890"
CLINIC_EMAIL="kontak@dentalcarelite.id"

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=dentalcare
DB_USERNAME=dentalcare
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root
DB_FORWARD_PORT=3307

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@dentalcarelite.id"
MAIL_FROM_NAME="${APP_NAME}"

TWO_FACTOR_ISSUER="${APP_NAME}"
TWO_FACTOR_DIGITS=6
TWO_FACTOR_PERIOD=30
TWO_FACTOR_WINDOW=1
TWO_FACTOR_CHALLENGE_EXPIRES_MINUTES=10
TWO_FACTOR_MAX_ATTEMPTS=5
TWO_FACTOR_RECOVERY_CODES=8

GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI="http://localhost:8080/auth/google/callback"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

MIDTRANS_MERCHANT_ID=
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_CALLBACK_URL="${APP_URL}/payments/midtrans/callback"

APPOINTMENT_SLOT_MINUTES=30

VITE_APP_NAME="${APP_NAME}"
