APP_NAME="DentalCare Lite"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL="https://your-ngrok-or-cloudflare-url.example"
APP_BIND=127.0.0.1
APP_PORT=8080
VITE_PORT=5173

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_COMPANY_CODE=DCL
CLINIC_NAME="DentalCare Lite"
CLINIC_TAGLINE="Klinik gigi modern untuk keluarga dengan reservasi online yang mudah."
CLINIC_ADDRESS="Jl. Senyum Sehat No. 12, Jakarta"
CLINIC_PHONE="+62 812-3456-7890"
CLINIC_EMAIL="yourgmail@gmail.com"

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=dentalcare
DB_USERNAME=dentalcare
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root
DB_FORWARD_PORT=3307

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
CACHE_PREFIX=

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME="yourgmail@gmail.com"
MAIL_PASSWORD="your-16-character-gmail-app-password"
MAIL_FROM_ADDRESS="yourgmail@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"

LOGIN_OTP_DIGITS=6
LOGIN_OTP_EXPIRES_MINUTES=10
LOGIN_OTP_MAX_ATTEMPTS=5
LOGIN_OTP_RESEND_COOLDOWN_SECONDS=60

# Optional. Leave empty if Google login is not needed for the presentation.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Midtrans sandbox. Leave keys empty to use the app's mock fallback.
MIDTRANS_MERCHANT_ID=
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_CALLBACK_URL="${APP_URL}/payments/midtrans/callback"

APPOINTMENT_SLOT_MINUTES=30
VITE_APP_NAME="${APP_NAME}"
